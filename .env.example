# =============================================================================
# PwNotify — Beispiel-Konfiguration.  Kopiere nach `.env` und passe an.
# ENV dient NUR als Initial-Seed beim allerersten Start; danach werden Settings
# in der DB verwaltet (Settings-UI / Setup-Wizard).  Geheimnisse werden at-rest
# mit Fernet verschlüsselt in der DB abgelegt.
# =============================================================================

# ---- Kern / Sicherheit ------------------------------------------------------
# Fernet-Master-Key für die at-rest-Verschlüsselung der Secrets in der DB.
# Leer lassen -> wird beim ersten Start generiert und in /data/secret.key (0600)
# persistiert.  Für Multi-Node / externes Secret-Management hier explizit setzen:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
PWNOTIFY_SECRET_KEY=

# Log-Level: DEBUG | INFO | WARNING | ERROR
PWNOTIFY_LOG_LEVEL=INFO
# JSON-Logs (true) oder farbige Konsolen-Logs (false, nur Dev)
PWNOTIFY_LOG_JSON=true

# Öffentliche Basis-URL der App (für Links in E-Mails, Cookie-Domain, OIDC-Redirect)
PWNOTIFY_BASE_URL=http://localhost:8080
# Secure-Cookies erzwingen (hinter HTTPS/Reverse-Proxy = true)
PWNOTIFY_COOKIE_SECURE=false

# Host-Port-Bindung des Containers.
#   127.0.0.1:8080  -> nur lokal erreichbar (sicherer Default, hinter Reverse-Proxy)
#   0.0.0.0:8080    -> im gesamten LAN erreichbar (z. B. http://10.10.10.170:8080)
# Ohne TLS davor: nur in vertrauenswürdigen Netzen auf 0.0.0.0 stellen.
PWNOTIFY_BIND=127.0.0.1:8080

# ---- Datenbank --------------------------------------------------------------
# Async-DSN (asyncpg).  In docker-compose zeigt der Host auf den DB-Service "db".
PWNOTIFY_DATABASE_URL=postgresql+asyncpg://pwnotify:change-me-strong@db:5432/pwnotify

# Wird nur vom postgres-Container / docker-compose genutzt:
POSTGRES_USER=pwnotify
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=pwnotify

# ---- Erst-Admin (optionaler Seed; sonst via Setup-Wizard) -------------------
# Wenn beide gesetzt sind und noch kein Admin existiert, wird er beim Start angelegt.
PWNOTIFY_ADMIN_USERNAME=
PWNOTIFY_ADMIN_PASSWORD=

# ---- Microsoft Graph / Entra ID (App Registration, Client Credentials) ------
PWNOTIFY_GRAPH_TENANT_ID=
PWNOTIFY_GRAPH_CLIENT_ID=
PWNOTIFY_GRAPH_CLIENT_SECRET=
# Graph-Cloud: global | usgov | china  (Default global)
PWNOTIFY_GRAPH_CLOUD=global

# ---- Mailversand ------------------------------------------------------------
# Backend: graph | smtp
PWNOTIFY_MAIL_BACKEND=graph
PWNOTIFY_MAIL_FROM=passwortablauf@example.com
# Empfänger-Strategie: primary | alternate | both | alternate_fallback_primary
PWNOTIFY_MAIL_RECIPIENT_STRATEGY=primary

# SMTP (nur wenn MAIL_BACKEND=smtp)
PWNOTIFY_SMTP_HOST=
PWNOTIFY_SMTP_PORT=587
PWNOTIFY_SMTP_USERNAME=
PWNOTIFY_SMTP_PASSWORD=
# TLS-Mode: starttls | ssl | none
PWNOTIFY_SMTP_TLS=starttls

# ---- Scheduler --------------------------------------------------------------
# Cron-Ausdruck (5 Felder) + Zeitzone
PWNOTIFY_SCHEDULE_CRON=0 8 * * *
PWNOTIFY_TIMEZONE=Europe/Zurich
# Reminder-Stufen in Tagen vor Ablauf (kommagetrennt)
PWNOTIFY_REMINDER_DAYS=14,7,3,1,0
# Dry-Run: alles berechnen/loggen, nichts versenden
PWNOTIFY_DRY_RUN=false
# Passwort-Gültigkeit manuell überschreiben (Tage). Leer = aus Domain-Policy lesen.
PWNOTIFY_PASSWORD_VALIDITY_DAYS=

# ---- Branding (überschreibbar im UI) ----------------------------------------
PWNOTIFY_APP_NAME=PwNotify
PWNOTIFY_COMPANY_NAME=
PWNOTIFY_PRIMARY_COLOR=#4F46E5
# URL, unter der Nutzer ihr Passwort zurücksetzen (SSPR / on-prem)
PWNOTIFY_RESET_URL=https://account.activedirectory.windowsazure.com/ChangePassword.aspx
