# =============================================================================
# PwNotify — Production-Umgebungsdatei.
# Kopieren nach `.env`  (docker compose liest automatisch `.env`):
#     cp example.env .env
# Danach mindestens die mit [ÄNDERN] markierten Werte setzen.
#
# ENV dient NUR als Initial-Seed beim allerersten Start. Danach werden alle
# Einstellungen in der DB verwaltet (Setup-Wizard / Settings-UI). Secrets werden
# at-rest mit Fernet verschlüsselt in der DB abgelegt.
# =============================================================================

# ---- Image ------------------------------------------------------------------
# Optional per Digest pinnen für unveränderliche Deployments:
#   PWNOTIFY_IMAGE=amslertec/pwnotify:0.1.1@sha256:<digest>
PWNOTIFY_IMAGE=amslertec/pwnotify:0.1.1

# ---- Datenbank  [ÄNDERN] ----------------------------------------------------
# Starkes, zufälliges Passwort setzen (z. B. `openssl rand -base64 24`).
POSTGRES_USER=pwnotify
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=pwnotify

# ---- Kern / Sicherheit ------------------------------------------------------
# Fernet-Master-Key für die at-rest-Verschlüsselung der Secrets.
# Leer lassen -> wird beim ersten Start generiert und in /data/secret.key (0600)
# persistiert. Für Backups/Multi-Node hier explizit setzen:
#   docker run --rm amslertec/pwnotify:0.1.1 python -c \
#     "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
PWNOTIFY_SECRET_KEY=

# ---- Netzwerkzugriff  [ÄNDERN je nach Szenario] ----------------------------
# Diese DREI Variablen zusammen bestimmen, wie die App erreichbar ist.
#
# SZENARIO A — direkter Zugriff im LAN, ohne Reverse-Proxy (z. B. zum Testen):
#   PWNOTIFY_BIND=0.0.0.0:8080
#   PWNOTIFY_BASE_URL=http://<server-ip>:8080     (z. B. http://10.10.10.180:8080)
#   PWNOTIFY_COOKIE_SECURE=false                  (Pflicht bei reinem HTTP, sonst kein Login)
#
# SZENARIO B — hinter TLS-Reverse-Proxy (empfohlen für Produktiv):
#   PWNOTIFY_BIND=127.0.0.1:8080                  (nur lokal, Proxy spricht mit dem Container)
#   PWNOTIFY_BASE_URL=https://pwnotify.example.com
#   PWNOTIFY_COOKIE_SECURE=true
#
# Hinweis: 127.0.0.1 = nur localhost -> ein Browser auf einem ANDEREN Gerät bekommt sonst
# "ERR_CONNECTION_REFUSED". Für LAN-Zugriff also 0.0.0.0 verwenden.
PWNOTIFY_BIND=0.0.0.0:8080
PWNOTIFY_BASE_URL=http://localhost:8080
PWNOTIFY_COOKIE_SECURE=false

# Logging
PWNOTIFY_LOG_LEVEL=INFO
PWNOTIFY_LOG_JSON=true
PWNOTIFY_TIMEZONE=Europe/Zurich

# ---- Erst-Admin (optionaler Seed) -------------------------------------------
# Leer lassen -> Admin wird im Setup-Wizard beim ersten Aufruf angelegt.
# Wenn beide gesetzt sind und noch kein Admin existiert, wird er beim Start erstellt.
PWNOTIFY_ADMIN_USERNAME=
PWNOTIFY_ADMIN_PASSWORD=

# ---- Microsoft Graph / Entra ID ---------------------------------------------
# Optional als Seed — kann auch komplett im Setup-Wizard / Settings-UI erfolgen.
PWNOTIFY_GRAPH_TENANT_ID=
PWNOTIFY_GRAPH_CLIENT_ID=
PWNOTIFY_GRAPH_CLIENT_SECRET=

# ---- Mailversand ------------------------------------------------------------
# Backend: graph | smtp  (Details/SMTP-Felder im Setup-Wizard bzw. Settings-UI)
PWNOTIFY_MAIL_BACKEND=graph
PWNOTIFY_MAIL_FROM=
