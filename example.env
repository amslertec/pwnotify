# =============================================================================
# PwNotify — production environment file.
#
# Copy to `.env` (docker compose reads it automatically):
#     cp example.env .env
# Then set at least the values marked [CHANGE ME].
#
# These variables are only the INITIAL SEED for the very first start. After that,
# all application settings live in the database and are managed through the setup
# wizard and the Settings UI. Secrets are encrypted at rest (Fernet).
# =============================================================================

# ---- Image ------------------------------------------------------------------
# Optionally pin by digest for immutable deployments:
#   PWNOTIFY_IMAGE=amslertec/pwnotify:0.3.5@sha256:<digest>
PWNOTIFY_IMAGE=amslertec/pwnotify:0.3.5

# Database image. Defaults to the hardened PostgreSQL 18 (0 known HIGH/CRITICAL
# CVEs) — same server as postgres:18-alpine, digest-pinned in the compose file.
# To use stock Postgres instead, set e.g.:
#   PWNOTIFY_DB_IMAGE=postgres:18-alpine
# PWNOTIFY_DB_IMAGE=amslertec/pwnotifydb:18

# ---- Database  [CHANGE ME] --------------------------------------------------
# Use a strong, random password (e.g. `openssl rand -base64 24`).
#
# TLS to the database: append `?ssl=require` (or `?ssl=verify-full`) to
# PWNOTIFY_DATABASE_URL. Not needed for the bundled Postgres — it sits on an internal
# Docker network — but do use it whenever the database lives on another host, otherwise
# the decrypted secrets travel in the clear.
POSTGRES_USER=pwnotify
# REQUIRED. Leave empty here and set your own value — a non-empty placeholder would slip
# past the `${POSTGRES_PASSWORD:?}` guard in docker-compose-prod.yml and start the instance
# with a password that is published in this repository. Empty makes compose refuse to start.
POSTGRES_PASSWORD=
POSTGRES_DB=pwnotify

# ---- Runtime DB role  [CHANGE ME] --------------------------------------------
# The app connects to Postgres as a dedicated NON-superuser role (pwnotify_runtime)
# for all tenant-scoped queries, so tenant isolation (RLS) cannot be bypassed even
# if a tenant route were compromised. Migrations/DDL still run as POSTGRES_USER.
# Provisioned automatically on first start with this password. Use a strong value
# (e.g. `openssl rand -base64 24`).
# REQUIRED. Leave empty here — a placeholder would slip past the `:?` guard and start the
# runtime DB role with a password published in this repository. Empty → compose refuses to start.
PWNOTIFY_RUNTIME_DB_PASSWORD=

# ---- Core / security --------------------------------------------------------
# Fernet master key for encrypting secrets at rest.
# Leave empty -> generated on first start and stored in /data/secret.key (0600).
# Set it explicitly for backups or multi-node setups:
#   docker run --rm amslertec/pwnotify:0.3.5 python -c \
#     "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
#
# BACK THIS UP. Without the key, the encrypted Graph and SMTP secrets in the
# database cannot be decrypted and must be re-entered.
#
# ROTATING THE KEY: pass several keys, comma-separated. Encryption always uses the
# FIRST one, decryption the first that fits — so a rotation needs no downtime and no
# re-entering of secrets:
#   1) put the new key first:   PWNOTIFY_SECRET_KEY=<new>,<old>   -> restart
#      (everything stays readable, new writes already use the new key)
#   2) re-encrypt existing values: save once in Settings, or simply wait until they
#      are changed anyway
#   3) drop the old key:        PWNOTIFY_SECRET_KEY=<new>
# Removing the old key too early makes values encrypted with it unreadable.
PWNOTIFY_SECRET_KEY=

# =============================================================================
# NETWORK ACCESS  [CHANGE ME depending on your setup]
#
# Pick ONE of the scenarios below and copy its four values. The scenarios differ
# in how the app is reached — and, importantly, in how it identifies clients.
# Getting PWNOTIFY_TRUSTED_PROXIES wrong does not break access, but it silently
# weakens brute-force protection, so read the section before changing it.
# =============================================================================

# -----------------------------------------------------------------------------
# SCENARIO A — direct access on the LAN, no reverse proxy (testing, trusted LAN)
#
#   PWNOTIFY_BIND=0.0.0.0:8080
#   PWNOTIFY_BASE_URL=http://<server-ip>:8080        # e.g. http://10.10.10.180:8080
#   PWNOTIFY_COOKIE_SECURE=false                     # required on plain HTTP, or login fails
#   PWNOTIFY_TRUSTED_PROXIES=127.0.0.1               # default; header ignored, real peer IP counts
#
# Note: binding to 127.0.0.1 here would make the app unreachable from other
# machines ("ERR_CONNECTION_REFUSED"). Use 0.0.0.0 for LAN access.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# SCENARIO B — reverse proxy on a SEPARATE server (recommended for production)
#
#   PWNOTIFY_BIND=0.0.0.0:8080                       # the proxy is another machine — 127.0.0.1 would lock it out
#   PWNOTIFY_BASE_URL=https://pwnotify.example.com
#   PWNOTIFY_COOKIE_SECURE=true
#   PWNOTIFY_TRUSTED_PROXIES=10.10.10.200            # your proxy's LAN IP
#
# Requests from another host are only DNAT'ed, so their source address survives:
# the app really sees 10.10.10.200 and the setting works as written. Only that one
# address may then set X-Forwarded-For — any other machine on the LAN cannot forge
# it, even though the port is open.
#
# Recommended in addition: firewall port 8080 so only the proxy may reach it, e.g.
#   ufw allow from 10.10.10.200 to any port 8080 proto tcp
#   ufw deny 8080
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# SCENARIO C — reverse proxy on the SAME host as PwNotify
#
#   PWNOTIFY_BIND=127.0.0.1:8080                     # proxy reaches it over localhost
#   PWNOTIFY_BASE_URL=https://pwnotify.example.com
#   PWNOTIFY_COOKIE_SECURE=true
#   PWNOTIFY_TRUSTED_PROXIES=172.16.0.0/12           # the Docker bridge range — NOT the host's own IP
#
# Counter-intuitive but verified: for requests from the host itself, Docker rewrites
# the source address, so the app sees the Docker gateway (172.x.0.1) and never the
# host's LAN address. Entering that address would silently do nothing — the header
# would be ignored and every user would share one rate limit.
#
# Cleanest alternative: run the proxy as a container on the same Docker network,
# drop `ports:` from the app service, and enter the proxy container's own IP:
#   docker inspect <proxy-container> \
#     --format '{{range .NetworkSettings.Networks}}{{.IPAddress}} {{end}}'
# -----------------------------------------------------------------------------

# Leave BIND and COOKIE_SECURE commented out: the compose file already ships secure
# defaults — it binds the app to 127.0.0.1 only (`${PWNOTIFY_BIND:-127.0.0.1:8080}`) and
# sets `${PWNOTIFY_COOKIE_SECURE:-true}` (which also enables HSTS). Setting them here as
# below would OVERRIDE those safe defaults and expose the app on the whole LAN with
# non-Secure session cookies over plain HTTP. Only uncomment for direct LAN access behind a
# TLS-terminating reverse proxy, and understand the consequences.
#PWNOTIFY_BIND=0.0.0.0:8080
PWNOTIFY_BASE_URL=http://localhost:8080
#PWNOTIFY_COOKIE_SECURE=false

# =============================================================================
# TRUSTED PROXIES — who may claim a client's IP address
#
# Only requests coming FROM these peers may override the client IP via the
# `X-Forwarded-For` header.
#
# Why it matters: the login rate limit and the account lockout are keyed on the
# client IP. If any client is trusted ("*"), an attacker simply sets the header
# himself, looks like a brand-new client on every attempt, and both protections
# stop working. This was a real bypass, fixed in 0.1.11.
#
# WHAT TO SET — depends on WHERE the proxy runs. This trips people up, so the
# rule of thumb is: enter the address the app actually SEES, not the one you think
# it should see.
#
#   No reverse proxy (Scenario A)
#       -> keep 127.0.0.1. The header is ignored and the real peer IP is used.
#
#   Proxy on a SEPARATE server (Scenario B)
#       -> enter the proxy's LAN IP, e.g. PWNOTIFY_TRUSTED_PROXIES=10.10.10.200
#          Requests from another host keep their source address (DNAT only), so
#          this works exactly as written and is the tightest, clearest setup.
#          Multiple proxies: comma-separated, e.g. "10.10.10.200,10.10.10.201".
#
#   Proxy on the SAME host, app port published (Scenario C)
#       -> PWNOTIFY_TRUSTED_PROXIES=172.16.0.0/12
#          Docker rewrites the source of host-local requests, so the app sees the
#          gateway (172.x.0.1), never the host's own LAN IP. The range covers
#          Docker's default bridge networks (172.16–172.31.x.x) and survives a
#          subnet change after `docker compose down`. Check yours with:
#            docker inspect <app-container> \
#              --format '{{range .NetworkSettings.Networks}}{{.Gateway}}{{end}}'
#          Trade-off: any process on that host can then forge the header —
#          acceptable while the port is bound to 127.0.0.1, and better than the
#          alternative (all users sharing one rate limit, so one attacker locks
#          everyone out). Never combine this range with PWNOTIFY_BIND=0.0.0.0.
#
#   Proxy as a CONTAINER on the same Docker network, port NOT published
#       -> enter the proxy container's IP, e.g. PWNOTIFY_TRUSTED_PROXIES=172.24.0.5
#
# VERIFY after changing: log in once, then check which address was recorded —
# it must be the real client IP, not a gateway:
#   docker compose exec db psql -U pwnotify -d pwnotify \
#     -c "SELECT ip_address, created_at FROM user_session ORDER BY created_at DESC LIMIT 3;"
#
# Never use "*". Comma-separated lists and CIDR ranges are supported.
# =============================================================================
PWNOTIFY_TRUSTED_PROXIES=127.0.0.1

# ---- Sessions ---------------------------------------------------------------
# Minutes of inactivity before a signed-in user is logged out automatically.
# Without it, a refresh token keeps a session alive for PWNOTIFY_REFRESH_TOKEN_TTL_DAYS
# (14 by default) — an unattended browser would stay logged in for two weeks.
#
# Two layers, because only the client can tell "working" from "tab left open":
#   * the browser signs out after this long without mouse/keyboard activity, even
#     with the tab open (it keeps polling in the background otherwise);
#   * the server ends idle sessions on the next token refresh — this catches a
#     closed browser or a stolen token.
# Either way the session row is DELETED, not just revoked.
#
# 0 disables it. Applies to local and SSO accounts alike.
PWNOTIFY_IDLE_TIMEOUT_MIN=30

# ---- Host header (optional) -------------------------------------------------
# Comma-separated list of accepted Host values, e.g. "pwnotify.example.com".
# Empty (default) = no check. Deliberately open: too narrow a list makes the app
# unreachable, while the gain is small — e-mail links and cookies come from
# PWNOTIFY_BASE_URL, not from the Host header. 127.0.0.1 and localhost always stay
# allowed so the container healthcheck keeps working.
PWNOTIFY_ALLOWED_HOSTS=

# ---- API docs (optional) ----------------------------------------------------
# Interactive OpenAPI docs (/api/docs) and the schema (/api/openapi.json).
# OFF by default: both publish the complete route map and request/response schemas
# to any anonymous caller. Enable only when you deliberately need them (e.g. during
# integration work), then disable again.
#PWNOTIFY_ENABLE_DOCS=false

# ---- Logging ----------------------------------------------------------------
PWNOTIFY_LOG_LEVEL=INFO
PWNOTIFY_LOG_JSON=true
PWNOTIFY_TIMEZONE=Europe/Zurich

# ---- First admin (optional seed) --------------------------------------------
# Leave empty -> the admin is created in the setup wizard on first visit.
# If both are set and no admin exists yet, the account is created on start.
PWNOTIFY_ADMIN_USERNAME=
PWNOTIFY_ADMIN_PASSWORD=

# ---- Microsoft Graph / Entra ID ---------------------------------------------
# Optional seed — can also be done entirely in the setup wizard / Settings UI.
PWNOTIFY_GRAPH_TENANT_ID=
PWNOTIFY_GRAPH_CLIENT_ID=
PWNOTIFY_GRAPH_CLIENT_SECRET=

# ---- Mail delivery ----------------------------------------------------------
# Backend: graph | smtp  (SMTP details are configured in the wizard / Settings UI)
PWNOTIFY_MAIL_BACKEND=graph
PWNOTIFY_MAIL_FROM=
