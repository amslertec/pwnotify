# =============================================================================
# PwNotify — production environment file.
#
# Copy to `.env` (docker compose reads it automatically):
#     cp example.env .env
# Then set at least the values marked [CHANGE ME].
#
# These variables are only the INITIAL SEED for the very first start. After that,
# all application settings live in the database and are managed through the setup
# wizard and the Settings UI. Secrets are encrypted at rest (Fernet).
# =============================================================================

# ---- Image ------------------------------------------------------------------
# Optionally pin by digest for immutable deployments:
#   PWNOTIFY_IMAGE=amslertec/pwnotify:0.1.11@sha256:<digest>
PWNOTIFY_IMAGE=amslertec/pwnotify:0.1.11

# ---- Database  [CHANGE ME] --------------------------------------------------
# Use a strong, random password (e.g. `openssl rand -base64 24`).
POSTGRES_USER=pwnotify
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=pwnotify

# ---- Core / security --------------------------------------------------------
# Fernet master key for encrypting secrets at rest.
# Leave empty -> generated on first start and stored in /data/secret.key (0600).
# Set it explicitly for backups or multi-node setups:
#   docker run --rm amslertec/pwnotify:0.1.11 python -c \
#     "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
#
# BACK THIS UP. Without the key, the encrypted Graph and SMTP secrets in the
# database cannot be decrypted and must be re-entered.
PWNOTIFY_SECRET_KEY=

# =============================================================================
# NETWORK ACCESS  [CHANGE ME depending on your setup]
#
# Pick ONE of the scenarios below and copy its four values. The scenarios differ
# in how the app is reached — and, importantly, in how it identifies clients.
# Getting PWNOTIFY_TRUSTED_PROXIES wrong does not break access, but it silently
# weakens brute-force protection, so read the section before changing it.
# =============================================================================

# -----------------------------------------------------------------------------
# SCENARIO A — direct access on the LAN, no reverse proxy (testing, trusted LAN)
#
#   PWNOTIFY_BIND=0.0.0.0:8080
#   PWNOTIFY_BASE_URL=http://<server-ip>:8080        # e.g. http://10.10.10.180:8080
#   PWNOTIFY_COOKIE_SECURE=false                     # required on plain HTTP, or login fails
#   PWNOTIFY_TRUSTED_PROXIES=127.0.0.1               # default; header ignored, real peer IP counts
#
# Note: binding to 127.0.0.1 here would make the app unreachable from other
# machines ("ERR_CONNECTION_REFUSED"). Use 0.0.0.0 for LAN access.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# SCENARIO B — behind a TLS reverse proxy (recommended for production)
#
#   PWNOTIFY_BIND=127.0.0.1:8080                     # local only; the proxy talks to it
#   PWNOTIFY_BASE_URL=https://pwnotify.example.com
#   PWNOTIFY_COOKIE_SECURE=true
#   PWNOTIFY_TRUSTED_PROXIES=172.16.0.0/12           # see "Trusted proxies" below — NOT the proxy's LAN IP
#
# Counter-intuitive but important: with a published port, Docker rewrites the
# source address of requests coming from the host. The container therefore sees
# the Docker gateway (172.x.0.1), NOT your proxy's LAN address. Entering the
# proxy's own IP (e.g. 10.10.10.200) has no effect — the app never sees it.
# -----------------------------------------------------------------------------

PWNOTIFY_BIND=0.0.0.0:8080
PWNOTIFY_BASE_URL=http://localhost:8080
PWNOTIFY_COOKIE_SECURE=false

# =============================================================================
# TRUSTED PROXIES — who may claim a client's IP address
#
# Only requests coming FROM these peers may override the client IP via the
# `X-Forwarded-For` header.
#
# Why it matters: the login rate limit and the account lockout are keyed on the
# client IP. If any client is trusted ("*"), an attacker simply sets the header
# himself, looks like a brand-new client on every attempt, and both protections
# stop working. This was a real bypass, fixed in 0.1.11.
#
# WHAT TO SET
#
#   No reverse proxy (Scenario A)
#       -> keep 127.0.0.1. The header is ignored and the real peer IP is used.
#
#   Reverse proxy, app port published via `ports:` (Scenario B — the common case,
#   including a proxy running on the host itself)
#       -> PWNOTIFY_TRUSTED_PROXIES=172.16.0.0/12
#          This covers Docker's default bridge networks (172.16–172.31.x.x).
#          Use the range rather than a single IP: Docker may pick a different
#          subnet after `docker compose down`.
#          Find your actual gateway with:
#            docker inspect <app-container> \
#              --format '{{range .NetworkSettings.Networks}}{{.Gateway}}{{end}}'
#
#          Do NOT enter the proxy's LAN IP (10.10.10.200, ...). Because of
#          Docker's NAT it never reaches the app, the setting silently does
#          nothing, and every user ends up sharing one rate limit.
#
#   Reverse proxy as a CONTAINER on the same Docker network, app port NOT published
#       -> enter the proxy container's IP, e.g. PWNOTIFY_TRUSTED_PROXIES=172.24.0.5
#            docker inspect <proxy-container> \
#              --format '{{range .NetworkSettings.Networks}}{{.IPAddress}} {{end}}'
#          This is the tightest option: remove `ports:` from the app service so
#          it is reachable only through the proxy.
#
# TRADE-OFF when trusting the bridge range with a published port: any process on
# the Docker host can then forge the header. That is acceptable when the port is
# bound to 127.0.0.1 (only local processes reach it) and the alternative is worse
# — without it, all users share a single rate limit and one attacker can lock
# everyone out. With PWNOTIFY_BIND=0.0.0.0 and no proxy, do NOT trust the range.
#
# Never use "*". Multiple entries are comma-separated. CIDR ranges are supported.
# =============================================================================
PWNOTIFY_TRUSTED_PROXIES=127.0.0.1

# ---- Logging ----------------------------------------------------------------
PWNOTIFY_LOG_LEVEL=INFO
PWNOTIFY_LOG_JSON=true
PWNOTIFY_TIMEZONE=Europe/Zurich

# ---- First admin (optional seed) --------------------------------------------
# Leave empty -> the admin is created in the setup wizard on first visit.
# If both are set and no admin exists yet, the account is created on start.
PWNOTIFY_ADMIN_USERNAME=
PWNOTIFY_ADMIN_PASSWORD=

# ---- Microsoft Graph / Entra ID ---------------------------------------------
# Optional seed — can also be done entirely in the setup wizard / Settings UI.
PWNOTIFY_GRAPH_TENANT_ID=
PWNOTIFY_GRAPH_CLIENT_ID=
PWNOTIFY_GRAPH_CLIENT_SECRET=

# ---- Mail delivery ----------------------------------------------------------
# Backend: graph | smtp  (SMTP details are configured in the wizard / Settings UI)
PWNOTIFY_MAIL_BACKEND=graph
PWNOTIFY_MAIL_FROM=
